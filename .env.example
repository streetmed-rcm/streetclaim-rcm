# ─── Athenahealth Integration ─────────────────────────────────────────────────
# OAuth2 client credentials for Athenahealth API access (client credentials flow)
ATHENA_CLIENT_ID=your_athenahealth_client_id
ATHENA_CLIENT_SECRET=your_athenahealth_client_secret

# Athenahealth practice ID (numeric, assigned by Athenahealth)
ATHENA_PRACTICE_ID=your_practice_id

# Base URL for Athenahealth API. Use the sandbox URL for development:
#   https://api.preview.platform.athenahealth.com
# Use the production URL for live data:
#   https://api.platform.athenahealth.com
ATHENA_BASE_URL=https://api.preview.platform.athenahealth.com
